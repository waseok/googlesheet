# (선택) 배포 도메인 — OG/파비콘 절대 URL용. 커스텀 도메인이면 https://실제도메인 형태로 설정
NEXT_PUBLIC_SITE_URL=

# Google Apps Script 웹앱 배포 URL (…/exec 로 끝나는 주소)
GAS_WEB_APP_URL=

# GAS 스크립트 속성 MUTATION_TOKEN 과 동일한 값 (완료 이동·되돌리기 API용, 서버에서만 사용)
GAS_MUTATION_TOKEN=

# 되돌리기 대상 폴더는 GAS 스크립트 속성 RESTORE_FOLDER_ID(선택)로 설정합니다. 미설정 시 실행 계정 Drive 루트로 이동합니다.
